const FIPS = {
  "01":"Alabama","02":"Alaska","04":"Arizona","05":"Arkansas","06":"California",
  "08":"Colorado","09":"Connecticut","10":"Delaware","12":"Florida","13":"Georgia",
  "15":"Hawaii","16":"Idaho","17":"Illinois","18":"Indiana","19":"Iowa",
  "20":"Kansas","21":"Kentucky","22":"Louisiana","23":"Maine","24":"Maryland",
  "25":"Massachusetts","26":"Michigan","27":"Minnesota","28":"Mississippi",
  "29":"Missouri","30":"Montana","31":"Nebraska","32":"Nevada","33":"New Hampshire",
  "34":"New Jersey","35":"New Mexico","36":"New York","37":"North Carolina",
  "38":"North Dakota","39":"Ohio","40":"Oklahoma","41":"Oregon","42":"Pennsylvania",
  "44":"Rhode Island","45":"South Carolina","46":"South Dakota","47":"Tennessee",
  "48":"Texas","49":"Utah","50":"Vermont","51":"Virginia","53":"Washington",
  "54":"West Virginia","55":"Wisconsin","56":"Wyoming"
};

/* populate dropdown */
const sel = document.getElementById('state-sel');
Object.keys(GOV).sort().forEach(s => {
  const o = document.createElement('option'); o.value = s; o.textContent = s; sel.appendChild(o);
});

const tt = document.getElementById('tooltip');
let pinnedState = null;

function makeImg(src, cssClass, fallbackClass) {
  const img = document.createElement('img');
  img.className = cssClass;
  img.onerror = function() {
    const ph = document.createElement('div');
    ph.className = fallbackClass;
    ph.textContent = '👤';
    this.replaceWith(ph);
  };
  img.src = src;
  return img;
}

function fillTooltip(state) {
  const g = GOV[state]; if (!g) return;
  const p = g.party;
  const pa = document.getElementById('tt-photo-area');
  pa.innerHTML = '';
  pa.appendChild(makeImg(g.img, 'tt-img', 'tt-img-ph'));
  document.getElementById('tt-bar').className = 'tt-bar ' + p;
  document.getElementById('tt-state').textContent = state;
  document.getElementById('tt-plbl').textContent = (p==='dem'?'Democratic':'Republican') + ' Governor';
  document.getElementById('tt-name').textContent = g.name;
  document.getElementById('tt-since').innerHTML = '<b>In office since:</b> ' + g.since;
  document.getElementById('tt-end').innerHTML = '<b>Term ends:</b> ' + g.end;
  document.getElementById('tt-badge').innerHTML = g.note ? `<span class="tt-badge ${p}">${g.note}</span>` : '';
}

function showTooltip(state, cx, cy) {
  fillTooltip(state);
  tt.style.display = 'block';
  positionTooltip(cx, cy);
}

function positionTooltip(cx, cy) {
  const tw = 230, th = 370;
  const vw = window.innerWidth, vh = window.innerHeight;
  let x = cx + 16, y = cy - 20;
  if (x + tw > vw - 8) x = cx - tw - 16;
  if (y + th > vh - 8) y = cy - th + 40;
  if (y < 5) y = 5;
  tt.style.left = x + 'px'; tt.style.top = y + 'px';
}

function hideTooltip() { tt.style.display = 'none'; }

function fillCard(state) {
  const g = GOV[state]; if (!g) return;
  const p = g.party;
  const pa = document.getElementById('gc-photo-area');
  pa.innerHTML = '';
  pa.appendChild(makeImg(g.img, 'gc-img', 'gc-img-ph'));
  document.getElementById('gc-bar').className = 'gc-bar ' + p;
  document.getElementById('gc-state').textContent = state;
  document.getElementById('gc-plbl').textContent = (p==='dem'?'Democratic':'Republican') + ' Governor';
  document.getElementById('gc-name').textContent = g.name;
  document.getElementById('gc-since').innerHTML = '<b>In office since:</b> ' + g.since;
  document.getElementById('gc-end').innerHTML = '<b>Term ends:</b> ' + g.end;
  document.getElementById('gc-badge').innerHTML = g.note ? `<span class="gc-badge ${p}">${g.note}</span>` : '';
  document.getElementById('gov-card').style.display = 'block';
  sel.value = state;
}

function pinState(state) {
  pinnedState = state;
  d3.selectAll('.state-path').classed('active', false);
  d3.selectAll('.state-path').filter(d => d.properties.name === state).classed('active', true);
  fillCard(state);
}

sel.addEventListener('change', e => { if (e.target.value) pinState(e.target.value); });

document.addEventListener('mousemove', e => {
  if (tt.style.display === 'block') positionTooltip(e.clientX, e.clientY);
});

fetch('https://cdn.jsdelivr.net/npm/us-atlas@3/states-10m.json')
  .then(r => r.json())
  .then(us => {
    const svg = d3.select('#map-svg');
    const proj = d3.geoAlbersUsa().scale(1300).translate([487, 305]);
    const pathGen = d3.geoPath().projection(proj);
    const states = topojson.feature(us, us.objects.states);
    states.features.forEach(f => { f.properties.name = FIPS[String(f.id).padStart(2,'0')] || ''; });

    svg.selectAll('path.state-path')
      .data(states.features)
      .join('path')
      .attr('class', d => 'state-path ' + ((GOV[d.properties.name]||{party:'rep'}).party))
      .attr('d', pathGen)
      .on('mousemove', function(event, d) {
        const name = d.properties.name;
        if (!name || !GOV[name]) return;
        if (!pinnedState) { d3.selectAll('.state-path').classed('active', false); d3.select(this).classed('active', true); }
        showTooltip(name, event.clientX, event.clientY);
      })
      .on('mouseleave', function() {
        if (!pinnedState) d3.select(this).classed('active', false);
        hideTooltip();
      })
      .on('click', function(event, d) {
        const name = d.properties.name;
        if (!name || !GOV[name]) return;
        if (pinnedState === name) {
          pinnedState = null;
          d3.select(this).classed('active', false);
          document.getElementById('gov-card').style.display = 'none';
          sel.value = '';
        } else { pinState(name); }
      });

    svg.append('path')
      .datum(topojson.mesh(us, us.objects.states, (a,b) => a !== b))
      .attr('fill','none').attr('stroke','#fff').attr('stroke-width','0.6')
      .attr('d', pathGen);
  });
</script>
</body>
</html>
